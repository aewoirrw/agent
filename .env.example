ZHIPU_API_KEY=your-api-key
# 兼容旧配置：若未设置 ZHIPU_API_KEY，则回退读取 DASHSCOPE_API_KEY
DASHSCOPE_API_KEY=
APP_NAME=SuperBizAgent-Python
PORT=9900
UPLOAD_PATH=./uploads
ALLOWED_EXTENSIONS=txt,md
# GLM 模型配置
CHAT_MODEL=glm-4.7-flash
EMBEDDING_MODEL=embedding-3
LOCAL_EMBEDDING_ENABLED=true
LOCAL_EMBEDDING_MODEL_PATH=./embedding_model
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=vector_store
RAG_TOP_K=3
DOCUMENT_CHUNK_MAX_SIZE=800
DOCUMENT_CHUNK_OVERLAP=100
PROMETHEUS_BASE_URL=http://localhost:9090
PROMETHEUS_MOCK_ENABLED=true
CLS_MOCK_ENABLED=true
EXTERNAL_TOOLS_CONFIG_PATH=
MCP_SERVERS_CONFIG_PATH=
